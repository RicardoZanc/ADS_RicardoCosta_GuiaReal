# Port where server will be running
PORT=3000

N8N_VERSION=stable

POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=n8n

RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

DATABASE_URL="postgresql://guiareal:guiareal@localhost:5434/guiareal?schema=public"

REDIS_URL="redis://localhost:6379"

REFRESH_TOKEN_TTL_SECONDS=86400

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# URL do frontend (CORS + cookies cross-origin)
CORS_ORIGIN=http://localhost:3001

REFRESH_COOKIE_NAME=guiareal_refresh
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Threshold pg_trgm para busca fuzzy de nodes (0.0 a 1.0)
NODES_SEARCH_FUZZINESS=0.3

# Chave para rotas /tool (n8n e automações) e base url usada para chamadas a tools
TOOL_BASE_URL=http://localhost:3000/tool 
TOOL_API_KEY=changeToolApiKey

# Webhook n8n para processamento de mensagens de chat
N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/chat-agent
# Quantidade de mensagens anteriores enviadas como contexto ao agente
CHAT_CONTEXT_MESSAGE_LIMIT=20

# Webhook n8n para revisão de fatos técnicos após denúncia
N8N_REPORT_WEBHOOK_URL=http://localhost:5678/webhook/report-fact-review

# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Supabase Storage (upload de imagens: buckets products, profiles e nodes)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=