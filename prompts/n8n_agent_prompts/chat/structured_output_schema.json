{
  "type": "object",
  "properties": {
    "chat_id": {
      "type": "string",
      "description": "UUID do chat, copiado exatamente do payload do webhook"
    },
    "title": {
      "type": "string",
      "description": "Título curto da conversa quando should_name_conversation for true; string vazia quando false",
      "maxLength": 255
    },
    "assistant_message": {
      "type": "string",
      "description": "Resposta completa ao usuário em pt-BR, formatada em Markdown (GFM)",
      "minLength": 1
    },
    "mentioned_technical_facts": {
      "type": ["array", "null"],
      "description": "Fatos técnicos usados na resposta, com evidências copiadas das tools",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "fact_label": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "source_type": { "type": "string", "enum": ["opinion", "thread"] },
                "source_id": { "type": "string", "format": "uuid" }
              },
              "required": ["source_type", "source_id"],
              "additionalProperties": false
            }
          }
        },
        "required": ["id", "fact_label", "evidence"],
        "additionalProperties": false
      }
    },
    "mentioned_evidences": {
      "type": ["array", "null"],
      "description": "União deduplicada de evidências (opiniões/threads) dos fatos utilizados",
      "items": {
        "type": "object",
        "properties": {
          "source_type": { "type": "string", "enum": ["opinion", "thread"] },
          "source_id": { "type": "string", "format": "uuid" }
        },
        "required": ["source_type", "source_id"],
        "additionalProperties": false
      }
    }
  },
  "required": ["chat_id", "title", "assistant_message"],
  "additionalProperties": false
}
