# Port where server will be running
PORT=

# Api key for openai
API_KEY=

N8N_VERSION=stable

POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=n8n

RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

DATABASE_URL="postgresql://guiareal:guiareal@localhost:5432/guiareal?schema=public"

# JWT de acesso (HS256). Defina um segredo forte em produção.
JWT_ACCESS_SECRET=
# Ex.: 15m, 1h (ver documentação do jsonwebtoken)
JWT_ACCESS_EXPIRES_IN=15m
# TTL do refresh token no Redis (segundos). Padrão 7 dias se omitido no código.
REFRESH_TOKEN_TTL_SECONDS=604800

# Redis — refresh tokens (fingerprint SHA-256)
REDIS_URL=redis://127.0.0.1:6379