# Port where server will be running
PORT=3000

N8N_VERSION=stable

POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=n8n

RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

DATABASE_URL="postgresql://guiareal:guiareal@localhost:5434/guiareal?schema=public"

REDIS_URL="redis://localhost:6379"

REFRESH_TOKEN_TTL_SECONDS=86400

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# Threshold pg_trgm para busca fuzzy de nodes (0.0 a 1.0)
NODES_SEARCH_FUZZINESS=0.3

# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO