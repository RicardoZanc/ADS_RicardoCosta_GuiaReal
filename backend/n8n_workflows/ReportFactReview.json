        }
      }
    },
    {
      "parameters": {
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "DELETE",
        "toolDescription": "Remove vínculo de evidência. Params: fact_id, source_type, source_id.",
        "url": "={{ $env.TOOL_BASE_URL }}/technical-facts/{{ $fromAI('fact_id') }}/evidence/{{ $fromAI('source_type') }}/{{ $fromAI('source_id') }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [920, 520],
      "id": "delete-fact-evidence",
      "name": "Delete Fact Evidence",
