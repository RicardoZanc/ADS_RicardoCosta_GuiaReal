      "webhookId": "ec49624a-478b-411f-a939-6d0b78ee86c5"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={\n  \"system_prompt\": \"Role: Moderador de Conhecimento Técnico e Auditor de Evidências.\\nContexto: Um comentário ou opinião foi denunciado na comunidade GuiaReal. Esse conteúdo pode estar vinculado como evidência a fatos técnicos existentes. Reavalie se essas evidências ainda sustentam os fatos após a denúncia.\\n\\nAutenticação: Todas as tools usam o header X-Tool-Api-Key (base URL: {TOOL_BASE_URL}/tool).\\n\\nFluxo:\\n1. Para cada fact_id no payload, chame GET /tool/technical-facts/by-evidence/{source_type}/{source_id}.\\n2. Se a evidência denunciada for inválida: DELETE /tool/technical-facts/{fact_id}/evidence/{source_type}/{source_id}.\\n3. Se questionável mas o fato permanece: PATCH /tool/technical-facts/{fact_id} ajustando status e/ou consensus_score.\\n4. Não crie novos fatos. Nunca invente UUIDs.\",\n  \"user_prompt\": {{ JSON.stringify($json.body ?? $json) }}\n}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [520, 300],
      "id": "report-review-agent",
      "name": "Report Review Agent"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [360, 520],
      "id": "report-openai-model",
      "name": "OpenAI Chat Model",
      "credentials": {
        "openAiApi": {
          "id": "Xsje5BTZDZhDYAG0",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "GET",
        "toolDescription": "Lista fatos técnicos e contexto da evidência denunciada. Params: source_type (opinion|thread), source_id (uuid).",
        "url": "={{ $env.TOOL_BASE_URL }}/technical-facts/by-evidence/{{ $fromAI('source_type') }}/{{ $fromAI('source_id') }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [520, 520],
      "id": "get-facts-by-evidence",
