generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model discussion_threads {
  id                       String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opinion_id               String?              @db.Uuid
  parent_interaction_id    String?              @db.Uuid
  user_id                  String               @db.Uuid
  content                  String
  cached_upvotes           Int?                 @default(0)
  status                   queue_status?        @default(PENDING)
  is_hidden                Boolean              @default(false)
  reports_locked           Boolean              @default(false)
  created_at               DateTime?            @default(now()) @db.Timestamptz(6)
  opinions                 opinions?            @relation(fields: [opinion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  discussion_threads       discussion_threads?  @relation("discussion_threadsTodiscussion_threads", fields: [parent_interaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_discussion_threads discussion_threads[] @relation("discussion_threadsTodiscussion_threads")
  users                    users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fact_evidence            fact_evidence[]
  reaction_votes           reaction_votes[]
  reports                  reports[]
}

model fact_evidence {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fact_id            String              @db.Uuid
  interaction_id     String?             @db.Uuid
  opinion_id         String?             @db.Uuid
  technical_facts    technical_facts     @relation(fields: [fact_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  discussion_threads discussion_threads? @relation(fields: [interaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  opinions           opinions?           @relation(fields: [opinion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([fact_id, interaction_id])
  @@unique([fact_id, opinion_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model nodes {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id       String?           @db.Uuid
  name            String            @db.VarChar(255)
  type            node_type
  wikidata_id     String?           @db.VarChar(50)
  image_url       String?
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  nodes           nodes?            @relation("nodesTonodes", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_nodes     nodes[]           @relation("nodesTonodes")
  opinions        opinions[]
  product_nodes   product_nodes[]
  technical_facts technical_facts[]
  user_interests  user_interests[]
}

model opinions {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String               @db.Uuid
  product_id         String?              @db.Uuid
  node_id            String?              @db.Uuid
  title              String?              @db.VarChar(255)
  content            String
  cached_upvotes     Int?                 @default(0)
  status             queue_status?        @default(PENDING)
  is_hidden          Boolean              @default(false)
  reports_locked     Boolean              @default(false)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  discussion_threads discussion_threads[]
  nodes              nodes?               @relation(fields: [node_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products           products?            @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reaction_votes     reaction_votes[]
  fact_evidence      fact_evidence[]
  reports            reports[]
}

model product_nodes {
  product_id String   @db.Uuid
  node_id    String   @db.Uuid
  nodes      nodes    @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, node_id])
}

model products {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @db.VarChar(255)
  ean           String?         @unique @db.VarChar(13)
  brand_name    String?         @db.VarChar(100)
  image_url     String?
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  opinions      opinions[]
  product_nodes product_nodes[]
}

model chats {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String          @db.Uuid
  title         String?         @db.VarChar(255)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)

  users         users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chat_messages chat_messages[]

  @@index([user_id])
}

model chat_messages {
  id                        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id                   String      @db.Uuid
  sender                    chat_sender
  content                   String      @db.Text
  mentioned_evidences       Json?
  mentioned_technical_facts Json?
  created_at                DateTime?   @default(now()) @db.Timestamptz(6)

  chats                     chats       @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chat_id])
  @@index([chat_id, created_at])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reaction_votes {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String              @db.Uuid
  interaction_id     String?             @db.Uuid
  opinion_id         String?             @db.Uuid
  vote_type          Int?                @default(1)
  discussion_threads discussion_threads? @relation(fields: [interaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  opinions           opinions?           @relation(fields: [opinion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model reports {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id           String              @db.Uuid
  target_interaction_id String?             @db.Uuid
  target_opinion_id     String?             @db.Uuid
  reason                String              @db.VarChar(50)
  status                report_status?      @default(PENDING)
  reviewer_id           String?             @db.Uuid
  reviewed_at           DateTime?           @db.Timestamptz(6)
  admin_notes           String?
  created_at            DateTime?           @default(now()) @db.Timestamp(6)
  users                 users               @relation("reports_reporter", fields: [reporter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer              users?              @relation("reports_reviewer", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  discussion_threads    discussion_threads? @relation(fields: [target_interaction_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  opinions              opinions?           @relation(fields: [target_opinion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([reporter_id, target_interaction_id])
  @@unique([reporter_id, target_opinion_id])
}

model technical_facts {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  node_id          String?         @db.Uuid
  fact_label       String
  fact_description String?
  consensus_score  Float?          @default(0)
  status           fact_status?    @default(HYPOTHESIS)
  last_updated     DateTime?       @default(now()) @db.Timestamp(6)
  fact_evidence    fact_evidence[]
  nodes            nodes?          @relation(fields: [node_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model change_requests {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String                 @db.Uuid
  entity_type      change_entity_type
  entity_id        String                 @db.Uuid
  changes          Json
  previous_state   Json
  status           change_request_status? @default(PENDING)
  reviewer_id      String?                @db.Uuid
  reviewed_at      DateTime?              @db.Timestamptz(6)
  rejection_reason String?
  created_at       DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?              @updatedAt @db.Timestamptz(6)
  users            users                  @relation("change_requests_submitted", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer         users?                 @relation("change_requests_reviewed", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@index([entity_type, entity_id])
  @@index([user_id])
}

model admin_requests {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String                @db.Uuid
  message          String
  status           admin_request_status? @default(PENDING)
  reviewer_id      String?               @db.Uuid
  reviewed_at      DateTime?             @db.Timestamptz(6)
  rejection_reason String?
  created_at       DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?             @updatedAt @db.Timestamptz(6)
  users            users                 @relation("admin_requests_submitted", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer         users?                @relation("admin_requests_reviewed", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
  @@index([status])
  @@index([user_id, status])
}

model users {
  id                       String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String?              @unique
  username                 String               @unique @db.VarChar(50)
  hashpassword             String
  reputation_score         Int?                 @default(0)
  avatar_url               String?
  is_banned                Boolean?             @default(false)
  is_admin                 Boolean              @default(false)
  created_at               DateTime?            @default(now()) @db.Timestamptz(6)
  deleted_at               DateTime?            @db.Timestamptz(6)
  chats                    chats[]
  discussion_threads       discussion_threads[]
  opinions                 opinions[]
  reaction_votes           reaction_votes[]
  reports_filed            reports[]            @relation("reports_reporter")
  reports_reviewed         reports[]            @relation("reports_reviewer")
  admin_requests_submitted admin_requests[]     @relation("admin_requests_submitted")
  admin_requests_reviewed  admin_requests[]     @relation("admin_requests_reviewed")
  change_requests_submitted change_requests[]   @relation("change_requests_submitted")
  change_requests_reviewed  change_requests[]   @relation("change_requests_reviewed")
  user_interests           user_interests[]
}

model user_interests {
  user_id    String   @db.Uuid
  node_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  nodes nodes @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, node_id])
  @@index([node_id])
}

enum chat_sender {
  USER
  ASSISTANT
}

enum fact_status {
  HYPOTHESIS
  VERIFIED
  DISPUTED
}

enum node_type {
  ROOT
  TIPO
  CATEGORIA
  COMPOSICAO
  TECNOLOGIA
  MARCA
  ATRIBUTO
}

enum opinion_sentiment {
  POSITIVO
  NEGATIVO
  MISTO
}

enum queue_status {
  PENDING
  PROCESSED
}

enum report_status {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum admin_request_status {
  PENDING
  APPROVED
  REJECTED
}

enum change_request_status {
  PENDING
  APPROVED
  REJECTED
}

enum change_entity_type {
  NODE
  PRODUCT
}
