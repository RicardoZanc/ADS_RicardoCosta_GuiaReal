# Copie para .env.local antes de rodar o frontend:
# cp example.env .env.local

# URL base da API do backend (usada em frontend/src/lib/api.ts)
# Deve incluir o prefixo /api. Padrão no código: http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Timeout de inatividade (ms) aguardando eventos do assistente via socket (default: 120000)
NEXT_PUBLIC_CHAT_ASSISTANT_INACTIVITY_TIMEOUT_MS=120000
